---
// Language detection — redirects client-side to /en/ or /es/
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Fallback for no-JS: go to English -->
    <meta http-equiv="refresh" content="0;url=/en/" />
    <title>Álvaro Barbero</title>
    <script is:inline>
      (function () {
        var lang = (navigator.language || navigator.languages?.[0] || 'en').toLowerCase();
        window.location.replace(lang.startsWith('es') ? '/es/' : '/en/');
      })();
    </script>
  </head>
  <body></body>
</html>
