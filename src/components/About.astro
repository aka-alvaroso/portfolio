<section id="about" class="relative pt-[calc(55vh+100px)] md:pt-[calc(55vh+100px)] pb-32">
  <!-- Strip: blue (left side) — mobile -->
  <div class="sm:hidden absolute left-0 pointer-events-none z-10" style="top: calc(55vh + 100px); width: 100vw; max-width: 420px;">
    <img src="/2026/strips/about-blue-mobile.svg" alt="" style="width: 100%; height: auto;" />
  </div>
  <!-- Strip: blue (left side) — desktop -->
  <div class="hidden sm:block absolute pointer-events-none z-10" style="top: calc(55vh - 100px); left: -8vw;">
    <svg style="width: clamp(400px, 45vw, 900px); height: auto;" viewBox="0 0 671 1876" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M-30 30.9489C488 167.096 638.5 166.738 638.5 547.596C638.5 663.596 409 612.096 409 883.596C409 1176.6 603 1821.1 -3.5 1843.1" stroke="#48ACF0" stroke-width="64"/>
    </svg>
  </div>

  <!-- Strip: yellow (right side) — mobile -->
  <div class="sm:hidden absolute right-0 pointer-events-none z-10" style="top: calc(55vh + 100px); width: 100vw; max-width: 420px;">
    <img src="/2026/strips/about-yellow-mobile.svg" alt="" style="width: 100%; height: auto;" />
  </div>
  <!-- Strip: yellow (right side) — desktop -->
  <div class="hidden sm:block absolute right-0 pointer-events-none z-10" style="top: calc(55vh + 150px);">
    <svg style="width: clamp(420px, 45vw, 950px); height: auto;" viewBox="0 0 751 1888" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M856.574 10.3792C695.074 481.379 -45.1262 -102.371 38.5746 481.379C122.275 1065.13 421.075 736.379 421.075 1018.38C421.075 1576.24 -18.4255 1648.88 803.574 1856.38" stroke="#FFDB4D" stroke-width="64"/>
    </svg>
  </div>

  <!-- Text -->
  <div class="relative z-0 w-full md:w-3/4 max-w-5xl mx-auto px-6 md:px-8">
    <p class="font-bold leading-[1.15] text-ink text-[clamp(1.75rem,4vw,3rem)]">
      I'm Álvaro, a 22-year-old developer from Spain. I don't just write code, I build products. From the first commit to deployment, I care about what I'm building and why.
    </p>
    <p class="font-bold leading-[1.15] text-ink mt-8 text-[clamp(1.75rem,4vw,3rem)]">
      Good software isn't just functional. It works, and it holds.
    </p>
  </div>
</section>
