---
import { ArrowUpRight } from "@lucide/astro";

const projects = [
  {
    id: "linkkk",
    name: "Linkkk.",
    description: "Link management with a conditional rules engine. Each link can redirect, block, require a password, or trigger a webhook based on who's accessing it, from where, and when.",
    image: "/2026/linkkk.png",
    href: "https://linkkk.dev/",
    strip: {
      viewBox: "0 0 1512 725",
      path: "M-14 658.521C278.833 692.854 606.487 520.511 540.5 282.022C343.5 -429.979 -595.5 863.521 1567.5 300.522",
      stroke: "#23CE6B",
    },
  },
  {
    id: "keypro",
    name: "KeyPro.",
    description: "Online typing trainer with multiplayer modes. Race against others, play in teams, or challenge yourself across multiple game modes.",
    image: "/2026/keypro.png",
    href: "https://alvaroso.dev/keypro/",
    strip: {
      viewBox: "0 0 1512 564",
      path: "M-64 22C-19.6667 147.167 180.6 239.2 471 166C834 74.5 312.5 542.983 875.5 498C1758 427.489 485.5 62 1557.5 62",
      stroke: "#48ACF0",
    },
  },
  {
    id: "moka",
    name: "Moka.",
    description: "Visual creator for social media content. Gradient backgrounds, animations, video export and iPhone mockup support.",
    image: "/2026/moka.png",
    href: "https://moka.so/",
    strip: {
      viewBox: "0 0 1512 620",
      path: "M-65 254.796C-20.6667 379.962 29.6 616.996 320 543.796C683 452.296 254 -183.231 888 165.796C1156 313.334 1304.5 588.796 1570.5 224.296",
      stroke: "#E63841",
    },
  },
];
---

<section id="projects" class="relative pt-24 pb-32">

  <!-- Title -->
  <h2 class="text-center font-black italic text-[clamp(2rem,5vw,3rem)] leading-tight text-ink mb-12 md:mb-20">
    Some of my<br/>work
  </h2>

  <!-- Projects track (will become sticky scroll in animation phase) -->
  <div id="projects-track">
    {projects.map((project) => (
      <div class="project-slide relative py-16 md:py-48" data-project={project.id}>

        <!-- Strip background -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
          <svg
            class="w-full h-full"
            viewBox={project.strip.viewBox}
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            preserveAspectRatio="xMidYMid slice"
          >
            <path
              d={project.strip.path}
              stroke={project.strip.stroke}
              stroke-width="124"
            />
          </svg>
        </div>

        <!-- Mockup -->
        <div class="relative z-10 max-w-5xl mx-auto px-4 md:px-8">
          <img
            src={project.image}
            alt={project.name}
            class="w-full rounded-2xl border-2 border-ink shadow-xl"
          />
        </div>

        <!-- Info row -->
        <div class="relative z-10 max-w-5xl mx-auto px-4 md:px-8 mt-6 md:mt-8 flex flex-col md:flex-row md:items-stretch md:justify-between gap-4 md:gap-8">
          <div class="max-w-sm">
            <h3 class="font-black italic text-[32px] leading-tight text-ink">{project.name}</h3>
            <p class="text-ink text-[18px] font-normal mt-2 leading-relaxed">{project.description}</p>
          </div>
          <a
            href={project.href}
            target="_blank"
            class="flex-shrink-0 bg-ink text-white font-black italic text-[18px] md:text-[22px] px-6 md:px-8 py-4 md:py-6 rounded-2xl flex items-center gap-3 hover:opacity-80 transition-opacity duration-200 w-fit md:w-auto"
          >
            Visit {project.name} <ArrowUpRight size={24} stroke-width={3} />
          </a>
        </div>

      </div>
    ))}
  </div>

</section>
