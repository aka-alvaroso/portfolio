---
import { ArrowUpRight, X, ChevronLeft, ChevronRight, Eye } from "@lucide/astro";
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projectStrips = [
  {
    id: "linkkk",
    image: "/2026/linkkk.png",
    images: [
      "/2026/projects/linkkk_1.png",
      "/2026/projects/linkkk_2.png",
      "/2026/projects/linkkk_3.png",
      "/2026/projects/linkkk_4.png",
    ],
    stack: ["Next.js", "TypeScript", "PostgreSQL", "Redis", "Tailwind CSS"],
    strip: {
      viewBox: "0 0 1512 725",
      path: "M-14 658.521C278.833 692.854 606.487 520.511 540.5 282.022C343.5 -429.979 -595.5 863.521 1567.5 300.522",
      stroke: "#23CE6B",
    },
  },
  {
    id: "moka",
    image: "/2026/moka.png",
    images: [
      "/2026/projects/moka_1.png",
      "/2026/projects/moka_2.png",
      "/2026/projects/moka_3.png",
    ],
    stack: ["React", "TypeScript", "Canvas API", "FFmpeg.wasm", "Tailwind CSS"],
    strip: {
      viewBox: "0 0 1512 620",
      path: "M-65 254.796C-20.6667 379.962 29.6 616.996 320 543.796C683 452.296 254 -183.231 888 165.796C1156 313.334 1304.5 588.796 1570.5 224.296",
      stroke: "#E63841",
    },
  },
  {
    id: "keypro",
    image: "/2026/keypro.png",
    images: [
      "/2026/projects/keypro_1.png",
      "/2026/projects/keypro_2.png",
      "/2026/projects/keypro_3.png",
    ],
    stack: ["React", "TypeScript", "WebSockets", "Tailwind CSS"],
    strip: {
      viewBox: "0 0 1512 564",
      path: "M-64 22C-19.6667 147.167 180.6 239.2 471 166C834 74.5 312.5 542.983 875.5 498C1758 427.489 485.5 62 1557.5 62",
      stroke: "#48ACF0",
    },
  },
];

const projects = t.projects.items.map((item) => ({
  ...item,
  ...projectStrips.find((s) => s.id === item.id)!,
}));
---

<section id="projects" class="relative pt-24 pb-32">

  <!-- Title -->
  <h2 class="text-center font-black italic text-[clamp(2rem,5vw,3rem)] leading-tight text-ink mb-12 md:mb-20">
    {t.projects.titleLine1}<br/>{t.projects.titleLine2}
  </h2>

  <!-- Projects track -->
  <div id="projects-track">
    {projects.map((project) => (
      <div class="project-slide relative py-16 md:py-48" data-project={project.id}>

        <!-- Strip background -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
          <svg
            class="w-full h-full"
            viewBox={project.strip.viewBox}
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            preserveAspectRatio="xMidYMid slice"
          >
            <path
              class="strip-projects"
              d={project.strip.path}
              stroke={project.strip.stroke}
              stroke-width="124"
            />
          </svg>
        </div>

        <!-- Mockup (clickable) -->
        <button
          class="relative z-10 max-w-5xl mx-auto px-4 md:px-8 w-full block group cursor-pointer"
          data-open-modal={JSON.stringify({
            name: project.name,
            tagline: project.tagline,
            why: project.why,
            features: project.features,
            stack: project.stack,
            images: project.images,
            year: project.year,
            href: project.href,
          })}
          aria-label={`${t.projects.modal.seeDetails} ${project.name}`}
        >
          <img
            src={project.image}
            alt={project.name}
            class="w-full rounded-2xl border-2 border-ink shadow-xl transition-opacity duration-200 group-hover:opacity-85"
          />
          <div class="absolute inset-4 md:inset-8 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none">
            <span class="bg-ink text-canvas font-black italic text-[1rem] px-5 py-3 rounded-2xl flex items-center gap-2 shadow-xl">
              {t.projects.modal.seeDetails}
              <Eye size={18} stroke-width={2.5} />
            </span>
          </div>
        </button>

        <!-- Info row -->
        <div class="relative z-10 max-w-5xl mx-auto px-4 md:px-8 mt-6 md:mt-8 flex flex-col md:flex-row md:items-stretch md:justify-between gap-4 md:gap-8">
          <div class="max-w-sm">
            <h3 class="font-black italic text-[32px] leading-tight text-ink">{project.name}</h3>
            <p class="text-ink text-[18px] font-normal mt-2 leading-relaxed">{project.description}</p>
          </div>

          <!-- Buttons -->
          <div class="flex flex-col xs:flex-row items-stretch xs:items-center gap-3 flex-shrink-0">
            <button
              class="border border-ink/25 text-ink font-black italic text-[16px] md:text-[18px] px-5 md:px-6 py-3 md:py-4 rounded-2xl flex items-center justify-center gap-2 hover:border-ink hover:bg-ink hover:text-canvas transition-colors duration-200 cursor-pointer"
              data-open-modal={JSON.stringify({
                name: project.name,
                tagline: project.tagline,
                why: project.why,
                features: project.features,
                stack: project.stack,
                images: project.images,
                period: project.period,
                href: project.href,
              })}
            >
              {t.projects.modal.seeDetails}
              <Eye size={18} stroke-width={2.5} />
            </button>
            <a
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-ink text-canvas font-black italic text-[16px] md:text-[18px] px-5 md:px-6 py-3 md:py-4 rounded-2xl flex items-center justify-center gap-2 hover:opacity-80 transition-opacity duration-200"
            >
              {t.projects.visit} <ArrowUpRight size={20} stroke-width={3} />
            </a>
          </div>
        </div>

      </div>
    ))}
  </div>

</section>

<!-- ─── Project Modal ─────────────────────────────────────────────────────────── -->
<div
  id="project-modal"
  class="fixed inset-0 z-[100] flex items-end md:items-center justify-center"
  style="display:none"
  aria-modal="true"
  role="dialog"
  aria-labelledby="modal-name"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0" style="background:rgba(19,19,19,0)"></div>

  <!-- Panel -->
  <div
    id="modal-panel"
    class="relative bg-canvas w-full max-w-3xl max-h-[92vh] md:max-h-[88vh] rounded-t-3xl md:rounded-3xl overflow-hidden flex flex-col shadow-[0_8px_48px_rgba(19,19,19,0.18)]"
    style="opacity:0;transform:translateY(60px)"
  >
    <!-- Header -->
    <div class="modal-content-block flex items-center justify-between px-5 md:px-8 py-4 md:py-5 border-b border-ink/[0.09] flex-shrink-0">
      <h2 id="modal-name" class="font-black italic text-[1.35rem] md:text-[1.7rem] leading-tight text-ink"></h2>
      <button
        id="modal-close"
        class="w-9 h-9 rounded-xl flex items-center justify-center text-ink/40 hover:text-ink hover:bg-ink/[0.07] transition-colors duration-200 flex-shrink-0 ml-4 cursor-pointer"
        aria-label="Close"
      >
        <X size={18} stroke-width={2.5} />
      </button>
    </div>

    <!-- Scrollable body -->
    <div class="overflow-y-auto flex-1">

      <!-- Carousel -->
      <div class="modal-content-block relative overflow-hidden bg-ink/[0.04]" style="aspect-ratio:16/9">
        <div id="modal-carousel-track" class="absolute inset-0">
          <!-- Images injected by JS -->
        </div>
        <button
          id="carousel-prev"
          class="absolute left-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 bg-canvas/90 shadow-sm rounded-full flex items-center justify-center text-ink/60 hover:text-ink hover:bg-canvas transition-colors duration-200 cursor-pointer"
          aria-label="Previous image"
        >
          <ChevronLeft size={16} stroke-width={3} />
        </button>
        <button
          id="carousel-next"
          class="absolute right-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 bg-canvas border-2 border-ink rounded-full flex items-center justify-center hover:bg-ink hover:text-canvas transition-colors duration-200 cursor-pointer"
          aria-label="Next image"
        >
          <ChevronRight size={16} stroke-width={3} />
        </button>
        <div id="carousel-dots" class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 z-10 pointer-events-auto">
          <!-- Dots injected by JS -->
        </div>
      </div>

      <!-- Tagline -->
      <div class="modal-content-block px-5 md:px-8 pt-6">
        <p id="modal-tagline" class="font-black italic text-[1.1rem] md:text-[1.3rem] text-ink leading-snug"></p>
      </div>

      <!-- Why + Features -->
      <div class="modal-content-block px-5 md:px-8 pt-5 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
        <div>
          <h3 class="font-black text-[0.68rem] uppercase tracking-widest text-ink/40 mb-2">{t.projects.modal.whyBuilt}</h3>
          <p id="modal-why" class="text-ink text-[0.93rem] leading-relaxed"></p>
        </div>
        <div>
          <h3 class="font-black text-[0.68rem] uppercase tracking-widest text-ink/40 mb-3">{t.projects.modal.features}</h3>
          <ul id="modal-features" class="flex flex-col gap-2.5">
            <!-- Injected by JS -->
          </ul>
        </div>
      </div>

      <!-- Stack + Visit -->
      <div class="modal-content-block px-5 md:px-8 py-6 mt-5 border-t border-ink/[0.09] flex flex-col gap-4">
        <div>
          <h3 class="font-black text-[0.68rem] uppercase tracking-widest text-ink/40 mb-3">{t.projects.modal.stack}</h3>
          <div id="modal-stack" class="flex flex-wrap gap-2">
            <!-- Injected by JS -->
          </div>
        </div>
        <div class="flex items-center justify-between">
          <span id="modal-year" class="font-black italic text-ink/30 text-[0.85rem]"></span>
          <a
            id="modal-visit"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-ink text-canvas font-black italic text-[0.95rem] md:text-[1.05rem] px-5 py-3 rounded-xl flex items-center gap-2 hover:opacity-80 transition-opacity duration-200"
          >
            {t.projects.visit} <ArrowUpRight size={18} stroke-width={3} />
          </a>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ─── Strip scroll animations ─────────────────────────────────────────────────
  if (!document.documentElement.hasAttribute('data-no-effects')) {
    document.querySelectorAll<SVGPathElement>('.strip-projects').forEach((path) => {
      const len = path.getTotalLength();
      gsap.set(path, { strokeDasharray: len, strokeDashoffset: len });
      const slide = path.closest('.project-slide');
      ScrollTrigger.create({
        trigger: slide, start: 'top 80%', once: true,
        onEnter: () => gsap.to(path, { strokeDashoffset: 0, duration: 2.5, ease: 'power1.inOut' }),
      });
    });
  }

  // ─── Modal ───────────────────────────────────────────────────────────────────

  interface ProjectModalData {
    name: string;
    tagline: string;
    why: string;
    features: string[];
    stack: string[];
    images: string[];
    period: string;
    href: string;
  }

  const modal    = document.getElementById('project-modal') as HTMLElement;
  const backdrop = document.getElementById('modal-backdrop') as HTMLElement;
  const panel    = document.getElementById('modal-panel') as HTMLElement;
  const closeBtn = document.getElementById('modal-close') as HTMLButtonElement;
  const prevBtn  = document.getElementById('carousel-prev') as HTMLButtonElement;
  const nextBtn  = document.getElementById('carousel-next') as HTMLButtonElement;
  const track    = document.getElementById('modal-carousel-track') as HTMLElement;
  const dotsEl   = document.getElementById('carousel-dots') as HTMLElement;

  let currentIndex = 0;
  let totalImages  = 0;

  // ─── Populate ────────────────────────────────────────────────────────────────
  function populate(data: ProjectModalData) {
    (document.getElementById('modal-name') as HTMLElement).textContent     = data.name;
    (document.getElementById('modal-tagline') as HTMLElement).textContent  = data.tagline;
    (document.getElementById('modal-why') as HTMLElement).textContent      = data.why;
    (document.getElementById('modal-year') as HTMLElement).textContent     = data.period;
    (document.getElementById('modal-visit') as HTMLAnchorElement).href     = data.href;

    (document.getElementById('modal-features') as HTMLElement).innerHTML = data.features
      .map(f => `<li class="flex items-start gap-2.5 text-ink text-[0.92rem] leading-snug">
        <span class="mt-0.5 flex-shrink-0 w-[18px] h-[18px] rounded-full bg-ink flex items-center justify-center">
          <svg width="9" height="7" viewBox="0 0 9 7" fill="none" aria-hidden="true">
            <path d="M1 3.5L3.2 5.5L8 1" stroke="#FEF9FF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        ${f}
      </li>`)
      .join('');

    (document.getElementById('modal-stack') as HTMLElement).innerHTML = data.stack
      .map(s => `<span class="bg-ink text-canvas font-bold text-[0.78rem] px-3 py-1 rounded-full">${s}</span>`)
      .join('');

    // Carousel setup
    totalImages  = data.images.length;
    currentIndex = 0;

    track.innerHTML = data.images
      .map(src => `<img src="${src}" alt="" class="absolute inset-0 w-full h-full object-contain" draggable="false" />`)
      .join('');

    const imgs = track.querySelectorAll<HTMLElement>('img');
    imgs.forEach((img, i) => gsap.set(img, { xPercent: i * 100 }));

    dotsEl.innerHTML = data.images
      .map((_, i) => `<button class="carousel-dot w-1.5 h-1.5 rounded-full bg-ink transition-opacity duration-300 cursor-pointer" style="opacity:${i === 0 ? '0.7' : '0.2'}" data-index="${i}" aria-label="Image ${i + 1}"></button>`)
      .join('');

    dotsEl.querySelectorAll<HTMLButtonElement>('.carousel-dot').forEach(dot => {
      dot.addEventListener('click', () => goTo(parseInt(dot.dataset.index!)));
    });

    updateArrows();
  }

  // ─── Carousel ────────────────────────────────────────────────────────────────
  function goTo(index: number) {
    const imgs = track.querySelectorAll<HTMLElement>('img');
    imgs.forEach((img, i) => {
      gsap.to(img, { xPercent: (i - index) * 100, duration: 0.45, ease: 'power2.inOut' });
    });
    dotsEl.querySelectorAll<HTMLElement>('.carousel-dot').forEach((dot, i) => {
      (dot as HTMLElement).style.opacity = i === index ? '0.7' : '0.2';
    });
    currentIndex = index;
    updateArrows();
  }

  function updateArrows() {
    prevBtn.style.opacity = currentIndex === 0 ? '0.3' : '1';
    nextBtn.style.opacity = currentIndex === totalImages - 1 ? '0.3' : '1';
  }

  prevBtn.addEventListener('click', () => { if (currentIndex > 0) goTo(currentIndex - 1); });
  nextBtn.addEventListener('click', () => { if (currentIndex < totalImages - 1) goTo(currentIndex + 1); });

  // Touch swipe
  let touchStartX = 0;
  track.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      if (diff > 0 && currentIndex < totalImages - 1) goTo(currentIndex + 1);
      else if (diff < 0 && currentIndex > 0) goTo(currentIndex - 1);
    }
  }, { passive: true });

  // ─── Open / Close ─────────────────────────────────────────────────────────────
  function openModal(data: ProjectModalData) {
    populate(data);
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    gsap.set(panel, { y: 60, opacity: 0 });
    gsap.set(backdrop, { backgroundColor: 'rgba(19,19,19,0)' });
    gsap.set('.modal-content-block', { y: 18, opacity: 0 });

    const tl = gsap.timeline();
    tl.to(backdrop, { backgroundColor: 'rgba(19,19,19,0.55)', duration: 0.35, ease: 'none' })
      .to(panel, { y: 0, opacity: 1, duration: 0.5, ease: 'power3.out' }, 0.05)
      .to('.modal-content-block', { y: 0, opacity: 1, stagger: 0.07, duration: 0.38, ease: 'power2.out' }, 0.28);
  }

  function closeModal() {
    gsap.timeline({
      onComplete: () => {
        modal.style.display = 'none';
        document.body.style.overflow = '';
      },
    })
      .to(panel, { y: 40, opacity: 0, duration: 0.3, ease: 'power2.in' })
      .to(backdrop, { backgroundColor: 'rgba(19,19,19,0)', duration: 0.25, ease: 'none' }, 0.05);
  }

  // ─── Events ──────────────────────────────────────────────────────────────────
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', (e) => {
    if (e.target === backdrop) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (modal.style.display === 'none') return;
    if (e.key === 'Escape') closeModal();
    if (e.key === 'ArrowLeft'  && currentIndex > 0)              goTo(currentIndex - 1);
    if (e.key === 'ArrowRight' && currentIndex < totalImages - 1) goTo(currentIndex + 1);
  });

  document.querySelectorAll<HTMLElement>('[data-open-modal]').forEach(trigger => {
    trigger.addEventListener('click', () => {
      openModal(JSON.parse(trigger.dataset.openModal!) as ProjectModalData);
    });
  });
</script>
