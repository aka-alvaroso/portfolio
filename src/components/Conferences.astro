          fill="#FFDB4D"></path>
      </svg>
      <span
        class="absolute text-[#FFDB4D] font-bold text-[16px] text-center leading-tight whitespace-nowrap"
        style="top: -10px; right: 30px; transform: rotate(35deg); transform-origin: left center;"
        >{t.conferences.hoverText}</span
      >
    </div>
  </div>
</section>
