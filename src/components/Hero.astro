---
import { ArrowUpRight, ChevronDown } from "@lucide/astro";
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 -mt-[55px]"
>
  <!-- Title -->
  <h1
    class="font-black italic leading-[1] text-ink max-w-5xl tracking-tight text-[clamp(2.5rem,8vw,6rem)]"
  >
    {t.hero.headline1}<br />
    {t.hero.headline2}
  </h1>

  <!-- CTAs -->
  <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6 mt-8 md:mt-10">
    <a
      href="mailto:hi@alvaroso.dev"
      class="bg-blue text-white font-semibold text-sm px-6 py-3 rounded-full flex items-center gap-2 hover:opacity-80 transition-opacity duration-200"
    >
      {t.hero.ctaWork}
      <ArrowUpRight size={16} stroke-width={2.5} />
    </a>

    <a
      href="#projects"
      class="text-ink font-medium text-sm flex items-center gap-2 hover:opacity-60 transition-opacity duration-200"
    >
      {t.hero.ctaSee}
      <ChevronDown size={18} stroke-width={2} />
    </a>
  </div>

  <!-- Strip: red — mobile (path reversed: top→bottom) -->
  <svg viewBox="0 0 402 605" fill="none" xmlns="http://www.w3.org/2000/svg"
    class="sm:hidden absolute left-0 w-full pointer-events-none" style="bottom: -25vh;">
    <path class="strip-hero-mobile" d="M-35 33.9421C41.3697 60.9361 115.547 168.768 178.276 435.487C207.692 560.562 306.934 560.997 476 568.942" stroke="#E63841" stroke-width="72"/>
  </svg>
  <!-- Strip: green — mobile (path reversed: top→bottom) -->
  <svg viewBox="0 0 402 613" fill="none" xmlns="http://www.w3.org/2000/svg"
    class="sm:hidden absolute right-0 w-full pointer-events-none" style="bottom: calc(-28vh - 150px);">
    <path class="strip-hero-mobile" d="M420.051 28.9207C306.888 82.5126 201.816 200.056 156.622 412.619C140.208 489.818 75.3287 547.204 -19.5 582.611" stroke="#23CE6B" stroke-width="64"/>
  </svg>

  <!-- Strip: red — tablet -->
  <svg viewBox="0 0 834 474" fill="none" xmlns="http://www.w3.org/2000/svg"
    class="hidden sm:block xl:hidden absolute left-0 pointer-events-none"
    style="bottom: -250px; width: 100%;">
    <path class="strip-hero-desktop" d="M-46.5044 49.5977C-14.3431 110.057 -18.2584 183.592 75.8806 178.072C197.617 170.935 419.352 -224.667 565 336.338C592.101 440.726 692.268 426.963 865.5 437.33" stroke="#E63841" stroke-width="72"/>
  </svg>
  <!-- Strip: green — tablet -->
  <svg viewBox="0 0 834 685" fill="none" xmlns="http://www.w3.org/2000/svg"
    class="hidden sm:block xl:hidden absolute right-0 pointer-events-none"
    style="bottom: -250px; width: 100%;">
    <path class="strip-hero-desktop" d="M853 31.0756C714.704 65.058 572.315 183.138 517.622 440.38C483.868 599.138 245.145 674.107 -37.5 646.44" stroke="#23CE6B" stroke-width="64"/>
  </svg>

  <!-- Strip: red — desktop -->
  <svg viewBox="0 0 1512 627" fill="none" xmlns="http://www.w3.org/2000/svg"
    class="hidden xl:block absolute left-0 w-full pointer-events-none"
    style="bottom: calc(-45vh - 75px);">
    <path class="strip-hero-desktop" d="M-44.25 100.623C-14.0229 65.4528 63.201 6.71863 130.28 53.1433C214.129 111.174 171.894 236.235 293.631 229.098C415.367 221.96 637.102 -173.642 782.75 387.364C828.75 564.546 1085.25 401.338 1552.25 593.494" stroke="#E63841" stroke-width="72"/>
  </svg>
  <!-- Strip: green — desktop -->
  <svg viewBox="0 0 1512 696" fill="none" xmlns="http://www.w3.org/2000/svg"
    class="hidden xl:block absolute left-0 w-full pointer-events-none"
    style="bottom: calc(-50vh - 75px);">
    <path class="strip-hero-desktop" d="M1618 68.4105C1462.88 -18.0617 1133.01 27.0027 1042.62 452.108C982.878 733.108 281 751.608 -170 403.108" stroke="#23CE6B" stroke-width="64"/>
  </svg>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  if (!document.documentElement.hasAttribute('data-no-effects')) {
    const section = document.querySelector('section');
    ['strip-hero-desktop', 'strip-hero-mobile'].forEach((cls) => {
      document.querySelectorAll<SVGPathElement>(`.${cls}`).forEach((path) => {
        const len = path.getTotalLength();
        gsap.set(path, { strokeDasharray: len, strokeDashoffset: len });
        gsap.to(path, {
          strokeDashoffset: 0, ease: 'none',
          scrollTrigger: { trigger: section, start: 'top top', end: 'bottom top', scrub: 2 },
        });
      });
    });
  }
</script>
