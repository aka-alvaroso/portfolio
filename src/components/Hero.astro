---
import { ArrowUpRight, ChevronDown } from "@lucide/astro";
---

<section
  class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 -mt-[55px]"
>
  <!-- Title -->
  <h1
    class="font-black italic text-[96px] leading-[1] text-ink max-w-5xl tracking-tight"
  >
    Software that ships.<br />
    Products that last.
  </h1>

  <!-- CTAs -->
  <div class="flex items-center gap-6 mt-10">
    <a
      href="mailto:hi@alvaroso.dev"
      class="bg-blue text-white font-semibold text-sm px-6 py-3 rounded-full flex items-center gap-2 hover:opacity-80 transition-opacity duration-200"
    >
      Let's work
      <ArrowUpRight size={16} stroke-width={2.5} />
    </a>

    <a
      href="#projects"
      class="text-ink font-medium text-sm flex items-center gap-2 hover:opacity-60 transition-opacity duration-200"
    >
      See my work
      <ChevronDown size={18} stroke-width={2} />
    </a>
  </div>

  <!-- Strip: red -->
  <svg
    id="hero-red"
    viewBox="0 0 1512 627"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="absolute left-0 w-full pointer-events-none"
    style="bottom: calc(-45vh - 75px);"
  >
    <path
      d="M-44.25 100.623C-14.0229 65.4528 63.201 6.71863 130.28 53.1433C214.129 111.174 171.894 236.235 293.631 229.098C415.367 221.96 637.102 -173.642 782.75 387.364C828.75 564.546 1085.25 401.338 1552.25 593.494"
      stroke="#E63841"
      stroke-width="72"></path>
  </svg>

  <!-- Strip: green -->
  <svg
    id="hero-green"
    viewBox="0 0 1512 696"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="absolute left-0 w-full pointer-events-none"
    style="bottom: calc(-50vh - 75px);"
  >
    <path
      d="M1618 68.4105C1462.88 -18.0617 1133.01 27.0027 1042.62 452.108C982.878 733.108 281 751.608 -170 403.108"
      stroke="#23CE6B"
      stroke-width="64"></path>
  </svg>
</section>
