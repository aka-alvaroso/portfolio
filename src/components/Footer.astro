---
import { ArrowUpRight, Pin, Share2 } from "@lucide/astro";
---

<!-- Contact + Footer -->
<section id="contact" class="relative pb-0 overflow-hidden">
  <!-- "Let's work together" with green oval -->
  <div style="height: 180px;"></div>
  <div class="relative flex flex-col items-center justify-center z-10">
    <!-- Green oval with circular text -->
    <div class="relative flex items-center justify-center">
      <svg
        width="370"
        height="172"
        viewBox="0 0 394 183"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="absolute"
        style="top: 35px;"
      >
        <path
          id="oval-stroke"
          d="M100.74 19.3921C-29.2599 -0.608147 -14.4832 200.698 205.24 158.892C420.741 117.889 397.74 47.3921 318.24 19.3921"
          stroke="#23CE6B"
          stroke-width="36"></path>
        <path
          id="oval-text-path"
          d="M100.74 19.3921C-29.2599 -0.608147 -14.4832 200.698 205.24 158.892C420.741 117.889 397.74 47.3921 318.24 19.3921"
          fill="none"
          stroke="none"></path>
        <text
          font-family="Inter, sans-serif"
          font-size="22"
          font-weight="900"
          fill="#131313"
          letter-spacing="1"
          dy="5"
        >
          <textPath href="#oval-text-path" startOffset="0%">
            · Scale · Create · Imagine · Design · Build · Ship · Ca
          </textPath>
        </text>
      </svg>

      <!-- Title -->
      <h2
        class="relative font-black italic text-[48px] leading-tight text-ink text-center z-10"
        style="padding: 20px 48px;"
      >
        Let's work<br />together
      </h2>
    </div>
  </div>

  <!-- Yellow arch footer -->
  <div class="relative mt-16">
    <svg
      class="w-full"
      viewBox="0 0 1512 727"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      style="display: block;"
    >
      <path
        d="M-652.5 678.902C-263 595.403 -158.5 340.971 752.5 314.39C1182.32 301.849 1539.5 584.383 1947.5 526.712"
        stroke="#FFDB4D"
        stroke-width="460"></path>
    </svg>

    <!-- Footer content overlaid on yellow -->
    <div class="absolute inset-0 flex flex-col items-center pt-16 px-16">
      <!-- Logo -->
      <svg
        width="48"
        height="44"
        viewBox="0 0 67 62"
        style="margin-top: 100px;"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M5.33929 21.453C24.8393 -1.54706 62.4194 3.72279 55.8394 31.4529C49.2593 59.1831 14.7325 59.987 14.7325 41.4983C14.7325 24.5437 53.0497 24.6244 59.3393 58.453"
          stroke="#131313"
          stroke-width="14"
          stroke-linecap="round"></path>
      </svg>

      <!-- Three columns -->
      <div class="w-full max-w-6xl grid grid-cols-3 gap-x-48 mt-16">
        <!-- Navigate -->
        <div>
          <p
            class="font-black text-[24px] text-ink mb-4 flex items-center gap-2"
          >
            Navigate <Pin size={16} stroke-width={2.5} />
          </p>
          <ul class="flex flex-col gap-2">
            <li>
              <a
                href="#projects"
                class="text-ink text-[24px] hover:opacity-60 transition-opacity"
                >Projects</a
              >
            </li>
            <li>
              <a
                href="#my-journey"
                class="text-ink text-[24px] hover:opacity-60 transition-opacity"
                >My journey</a
              >
            </li>
            <li>
              <a
                href="#talks"
                class="text-ink text-[24px] hover:opacity-60 transition-opacity"
                >Talks</a
              >
            </li>
          </ul>
        </div>

        <!-- Social media -->
        <div>
          <p
            class="font-black text-[24px] text-ink mb-4 flex items-center gap-2"
          >
            My social media <Share2 size={16} stroke-width={2.5} />
          </p>
          <ul class="flex flex-col gap-2">
            <li>
              <a
                href="https://go.alvaroso.dev/linkedin"
                target="_blank"
                class="text-ink text-[24px] hover:opacity-60 transition-opacity"
                >go.alvaroso.dev/linkedin</a
              >
            </li>
            <li>
              <a
                href="https://go.alvaroso.dev/x"
                target="_blank"
                class="text-ink text-[24px] hover:opacity-60 transition-opacity"
                >go.alvaroso.dev/x</a
              >
            </li>
            <li>
              <a
                href="https://go.alvaroso.dev/github"
                target="_blank"
                class="text-ink text-[24px] hover:opacity-60 transition-opacity"
                >go.alvaroso.dev/github</a
              >
            </li>
          </ul>
        </div>

        <!-- Get in touch -->
        <div class="flex flex-col gap-3">
          <a
            href="mailto:hi@alvaroso.dev"
            class="bg-blue text-white font-black text-[24px] px-6 py-4 rounded-2xl flex items-center gap-2 hover:opacity-80 transition-opacity w-fit"
          >
            Get in touch <ArrowUpRight size={20} stroke-width={3} />
          </a>
          <p class="text-ink text-[24px]">hi@alvaroso.dev</p>
        </div>
      </div>
      <!-- Made by -->
      <p class="text-ink text-[16px] mt-80">
        Made with 💙 by <a
          href="https://alvaroso.dev/"
          class="underline font-semibold hover:opacity-60 transition-opacity"
          >Alvaroso</a
        >
      </p>
    </div>
  </div>
</section>
