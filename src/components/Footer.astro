---
import { ArrowUpRight, Pin, BadgeCheck } from "@lucide/astro";
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<!-- Contact + Footer -->
<section id="contact" class="relative pb-0 overflow-hidden">
  <!-- "Let's work together" -->
  <div style="height: 180px;"></div>
  <div class="relative flex flex-col items-center justify-center z-10">
    <h2
      class="relative font-black italic text-[clamp(2rem,5vw,3rem)] leading-tight text-ink text-center z-10"
      style="padding: 16px 32px;"
    >
      {t.footer.title1}<br />{t.footer.title2}
    </h2>
  </div>

  <!-- Yellow arch footer -->
  <div class="relative mt-16">
    <!-- Yellow arch — mobile (CSS arch) -->
    <div class="absolute inset-0 sm:hidden" style="background: #FFDB4D; border-radius: 50% 50% 0 0 / 12% 12% 0 0;"></div>
    <!-- Yellow arch — tablet -->
    <svg class="absolute inset-0 w-full h-full hidden sm:block xl:hidden" viewBox="0 0 834 508" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path class="strip-footer" d="M977 310.6C802.991 255.071 625.492 201.798 433.5 207.4C209.733 213.929 34.6251 234.205 -108 262.318" stroke="#FFDB4D" stroke-width="414"/>
    </svg>
    <!-- Yellow arch — desktop -->
    <svg
      class="absolute inset-0 w-full h-full hidden xl:block"
      viewBox="0 0 1512 727"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
    >
      <path class="strip-footer"
        d="M-652.5 678.902C-263 595.403 -158.5 340.971 752.5 314.39C1182.32 301.849 1539.5 584.383 1947.5 526.712"
        stroke="#FFDB4D"
        stroke-width="628"></path>
    </svg>

    <!-- Footer content — drives the real height -->
    <div class="relative z-10 flex flex-col items-center pt-16 px-6 md:px-16 pb-12">
      <!-- Logo -->
      <img src="/2026/logo.svg" alt="Logo" style="margin-top: 40px; width: 48px; height: auto;" />

      <!-- Three columns -->
      <div class="w-full max-w-6xl grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-x-48 mt-6 md:mt-16">
        <!-- Navigate -->
        <div>
          <p class="font-black text-[clamp(16px,2vw,24px)] text-ink mb-3 flex items-center gap-2">
            {t.footer.navigate} <span style="display:inline-flex;transform:rotate(20deg);"><Pin size={32} stroke-width={3} /></span>
          </p>
          <ul class="flex flex-col gap-1">
            <li>
              <a href="#projects" class="text-ink text-[clamp(14px,1.8vw,24px)] hover:opacity-60 transition-opacity">{t.footer.navLinks.projects}</a>
            </li>
            <li>
              <a href="#my-journey" class="text-ink text-[clamp(14px,1.8vw,24px)] hover:opacity-60 transition-opacity">{t.footer.navLinks.journey}</a>
            </li>
            <li>
              <a href="#talks" class="text-ink text-[clamp(14px,1.8vw,24px)] hover:opacity-60 transition-opacity">{t.footer.navLinks.talks}</a>
            </li>
          </ul>
        </div>

        <!-- Social media -->
        <div>
          <p class="font-black text-[clamp(16px,2vw,24px)] text-ink mb-3 flex items-center gap-2">
            {t.footer.social} <span style="display:inline-flex;transform:rotate(20deg);"><BadgeCheck size={32} stroke-width={3} /></span>
          </p>
          <ul class="flex flex-col gap-1">
            <li>
              <a href="https://go.alvaroso.dev/linkedin" target="_blank" class="text-ink text-[clamp(12px,1.5vw,24px)] hover:opacity-60 transition-opacity">go.alvaroso.dev/linkedin</a>
            </li>
            <li>
              <a href="https://go.alvaroso.dev/twitter" target="_blank" class="text-ink text-[clamp(12px,1.5vw,24px)] hover:opacity-60 transition-opacity">go.alvaroso.dev/twitter</a>
            </li>
            <li>
              <a href="https://go.alvaroso.dev/github" target="_blank" class="text-ink text-[clamp(12px,1.5vw,24px)] hover:opacity-60 transition-opacity">go.alvaroso.dev/github</a>
            </li>
          </ul>
        </div>

        <!-- Get in touch -->
        <div class="flex flex-col gap-2">
          <a
            href="mailto:hi@alvaroso.dev"
            class="bg-blue text-white font-semibold text-[clamp(14px,1.8vw,24px)] px-5 py-3 rounded-2xl flex items-center gap-2 hover:opacity-80 transition-opacity w-fit"
          >
            {t.footer.touch} <ArrowUpRight size={32} stroke-width={3} />
          </a>
          <p class="text-ink text-[clamp(12px,1.5vw,24px)]">hi@alvaroso.dev</p>
        </div>
      </div>

      <!-- Made by + language switcher -->
      <div class="flex items-center gap-4 mt-12 md:mt-24">
        <p class="text-ink text-[14px]">
          {t.footer.madeBy} <a
            href="https://alvaroso.dev/"
            class="underline font-semibold hover:opacity-60 transition-opacity"
            >Alvaroso</a
          >
        </p>
        <span class="text-ink opacity-30 text-[14px]">·</span>
        <a
          href={t.nav.langSwitchHref}
          class="text-ink text-[14px] font-bold hover:opacity-60 transition-opacity"
        >
          {t.nav.langSwitch}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<SVGPathElement>('.strip-footer').forEach((path) => {
    const len = path.getTotalLength();
    gsap.set(path, { strokeDasharray: len, strokeDashoffset: len });

    ScrollTrigger.create({
      trigger: path.closest('section'),
      start: 'top 90%',
      once: true,
      onEnter: () => {
        gsap.to(path, {
          strokeDashoffset: 0,
          duration: 1.8,
          ease: 'power2.out',
        });
      },
    });
  });
</script>
