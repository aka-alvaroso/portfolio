---
const links = [
  { label: "Projects",   href: "#projects"   },
  { label: "My journey", href: "#my-journey" },
  { label: "Talks",      href: "#talks"      },
];
---

<header class="fixed top-0 left-0 w-full z-50">
  <!-- Yellow strip (hidden on mobile) -->
  <div class="absolute top-0 left-0 w-full hidden md:flex justify-center pointer-events-none overflow-hidden">
    <svg
      id="navbar-yellow"
      viewBox="0 0 1139 136"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="w-full max-w-[1139px]"
    >
      <path
        d="M26.3455 -39C172.304 56.8372 595.245 191.009 1119.35 -39"
        stroke="#FFDB4D"
        stroke-width="96"
      />
    </svg>
  </div>

  <!-- Nav content -->
  <nav class="relative flex items-start justify-between px-6 md:px-8 h-16 md:h-[136px]">
    <!-- Logo -->
    <a href="/" aria-label="Home" class="pt-4 md:pt-6">
      <svg
        id="logo"
        width="32"
        height="30"
        viewBox="0 0 67 62"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="md:w-10 md:h-[37px]"
      >
        <path
          d="M5.33929 21.453C24.8393 -1.54706 62.4194 3.72279 55.8394 31.4529C49.2593 59.1831 14.7325 59.987 14.7325 41.4983C14.7325 24.5437 53.0497 24.6244 59.3393 58.453"
          stroke="#131313"
          stroke-width="14"
          stroke-linecap="round"
        />
      </svg>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex absolute left-1/2 -translate-x-1/2 gap-8 list-none m-0 p-0" style="top: 77px;">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-ink text-sm font-medium hover:opacity-60 transition-opacity duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden pt-4 text-ink"
      aria-label="Menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-canvas border-t border-ink/10 px-6 py-4 flex flex-col gap-4"
  >
    {links.map((link) => (
      <a
        href={link.href}
        class="text-ink text-base font-medium hover:opacity-60 transition-opacity duration-200"
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });
</script>
