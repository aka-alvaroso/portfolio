---
import { X, Folder, Compass, Mic2 } from "@lucide/astro";
import Settings from './Settings.astro';
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { label: t.nav.projects, href: "#projects",   Icon: Folder  },
  { label: t.nav.journey,  href: "#my-journey", Icon: Compass },
  { label: t.nav.talks,    href: "#talks",       Icon: Mic2    },
];
---

<header class="fixed top-0 left-0 w-full z-50">
  <!-- Yellow strip — tablet -->
  <div class="absolute top-0 left-0 w-full hidden md:flex xl:hidden justify-center pointer-events-none overflow-hidden">
    <svg viewBox="0 0 720 133" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path id="navbar-strip-tablet" d="M34.8829 -39C122.618 53.8187 376.847 183.765 691.883 -39" stroke="#FFDB4D" stroke-width="96"/>
    </svg>
  </div>
  <!-- Yellow strip — desktop -->
  <div class="absolute top-0 left-0 w-full hidden xl:flex justify-center pointer-events-none overflow-hidden">
    <svg viewBox="0 0 1139 136" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-[1139px]">
      <path id="navbar-strip-desktop" d="M26.3455 -39C172.304 56.8372 595.245 191.009 1119.35 -39" stroke="#FFDB4D" stroke-width="96"/>
    </svg>
  </div>

  <!-- Nav content -->
  <nav class="relative flex items-start justify-between px-6 md:px-8 h-16 md:h-[136px]">
    <!-- Logo -->
    <a href={`/${lang}/`} aria-label="Home" class="pt-4 md:pt-6">
      <img src="/2026/logo.svg" alt="Logo" class="w-8 h-auto md:w-10" />
    </a>

    <!-- Desktop links -->
    <ul id="navbar-links" class="hidden md:flex absolute left-1/2 -translate-x-1/2 gap-8 list-none m-0 p-0" style="top: 77px;">
      {links.map(({ label, href, Icon }) => (
        <li class="nav-item relative">
          <a
            href={href}
            class="relative flex flex-col items-center text-ink text-sm font-medium hover:opacity-60 transition-opacity duration-200"
          >
            <span class="nav-icon absolute opacity-0" style="top: -22px;">
              <Icon size={16} stroke-width={3} />
            </span>
            <span class="nav-label">{label}</span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side: settings always visible, hamburger mobile only -->
    <div class="flex items-center gap-3 pt-4 md:pt-6">
      <Settings lang={lang} />
      <button id="mobile-menu-btn" class="text-ink md:hidden" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-[200] md:hidden">
    <svg
      viewBox="0 0 323 615"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
      class="absolute inset-0 w-full h-full pointer-events-none"
    >
      <path id="navbar-strip-mobile" d="M249.504 -148C171.778 -26.4794 62.961 325.649 249.504 762" stroke="#FFDB4D" stroke-width="293"/>
    </svg>

    <button id="mobile-menu-close" class="absolute top-5 right-5 z-20 text-ink" aria-label="Close menu">
      <X size={28} stroke-width={3} />
    </button>

    <div id="mobile-menu-links" class="relative z-10 flex flex-col gap-8 h-full justify-center pl-[20%]">
      {links.map(({ label, href, Icon }) => (
        <a
          href={href}
          class="mobile-nav-link flex items-center gap-3 text-ink text-2xl font-semibold hover:opacity-60 transition-opacity duration-200"
        >
          <Icon size={22} stroke-width={3} />
          {label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  import gsap from 'gsap';

  // ── Elements ──────────────────────────────────────────────────
  const desktopPath = document.getElementById('navbar-strip-desktop') as SVGPathElement | null;
  const tabletPath  = document.getElementById('navbar-strip-tablet')  as SVGPathElement | null;
  const mobilePath  = document.getElementById('navbar-strip-mobile')  as SVGPathElement | null;
  const navLinks    = document.getElementById('navbar-links');
  const mobileMenu  = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll<HTMLElement>('.mobile-nav-link');

  const noEffects = document.documentElement.hasAttribute('data-no-effects');
  const navStrips = [desktopPath, tabletPath].filter(Boolean) as SVGPathElement[];

  // ── Desktop / Tablet strip ─────────────────────────────────────
  if (!noEffects) {
    navStrips.forEach((path) => {
      const len = path.getTotalLength();
      gsap.set(path, { strokeDasharray: len, strokeDashoffset: len });
      gsap.to(path, { strokeDashoffset: 0, duration: 0.9, ease: 'power2.out', delay: 0.2 });
    });

    let lastY = 0, visible = true;
    function hideNav() {
      if (!visible) return; visible = false;
      navStrips.forEach((p) => gsap.to(p, { strokeDashoffset: p.getTotalLength(), duration: 0.4, ease: 'power2.in' }));
      if (navLinks) gsap.to(navLinks, { opacity: 0, y: -6, duration: 0.3, ease: 'power2.in', pointerEvents: 'none' });
    }
    function showNav() {
      if (visible) return; visible = true;
      navStrips.forEach((p) => gsap.to(p, { strokeDashoffset: 0, duration: 0.6, ease: 'power2.out' }));
      if (navLinks) gsap.to(navLinks, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out', pointerEvents: 'auto' });
    }
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y > lastY && y > 60) hideNav(); else if (y < lastY) showNav();
      lastY = y;
    }, { passive: true });
  }

  // ── Mobile menu ────────────────────────────────────────────────
  if (!noEffects && mobilePath) {
    const mobileLen = mobilePath.getTotalLength();
    gsap.set(mobilePath, { strokeDasharray: mobileLen, strokeDashoffset: mobileLen });
    gsap.set(mobileLinks, { opacity: 0, x: -20 });
  }

  function openMenu() {
    mobileMenu?.classList.remove('hidden');
    mobileMenu?.classList.add('flex');
    if (!noEffects) {
      if (mobilePath) gsap.to(mobilePath, { strokeDashoffset: 0, duration: 0.5, ease: 'power2.out' });
      gsap.to(mobileLinks, { opacity: 1, x: 0, duration: 0.35, stagger: 0.08, ease: 'power2.out', delay: 0.25 });
    } else {
      gsap.set(mobileLinks, { opacity: 1, x: 0 });
    }
  }

  function closeMenu() {
    if (!noEffects) {
      gsap.to(mobileLinks, { opacity: 0, x: -20, duration: 0.2, ease: 'power2.in', stagger: 0.05 });
      if (mobilePath) {
        gsap.to(mobilePath, {
          strokeDashoffset: mobilePath.getTotalLength(), duration: 0.4, ease: 'power2.in', delay: 0.15,
          onComplete: () => {
            mobileMenu?.classList.add('hidden');
            mobileMenu?.classList.remove('flex');
            gsap.set(mobileLinks, { opacity: 0, x: -20 });
          },
        });
      } else {
        mobileMenu?.classList.add('hidden');
        mobileMenu?.classList.remove('flex');
      }
    } else {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('flex');
    }
  }

  document.getElementById('mobile-menu-btn')?.addEventListener('click', openMenu);
  document.getElementById('mobile-menu-close')?.addEventListener('click', closeMenu);

  // ── Desktop nav icon hover ─────────────────────────────────────
  if (noEffects) { /* skip */ }
  else document.querySelectorAll('.nav-item').forEach((item) => {
    const icon = item.querySelector('.nav-icon') as HTMLElement;
    if (!icon) return;
    gsap.set(icon, { y: 8, opacity: 0, scale: 0.8 });
    item.addEventListener('mouseenter', () =>
      gsap.to(icon, { y: 0, opacity: 1, scale: 1.2, duration: 0.25, ease: 'power2.out' }));
    item.addEventListener('mouseleave', () =>
      gsap.to(icon, { y: 8, opacity: 0, scale: 0.8, duration: 0.2, ease: 'power2.in' }));
  })
</script>
